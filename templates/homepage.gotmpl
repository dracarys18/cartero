<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cartero</title>
    <link rel="icon" type="image/jpeg" href="/assets/favicon.jpg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background-color: #f4f1ea;
            color: #3a3a3a;
            font-family: Optima, "Trebuchet MS", sans-serif;
            line-height: 1.6;
            max-width: 1000px;
            margin: 0 auto;
            padding: 30px 20px;
            font-size: 16px;
        }
        a {
            color: #2c5f6f;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .header {
            border-bottom: 2px solid #d4cec0;
            padding: 20px 0;
            margin-bottom: 35px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-size: 26px;
            font-weight: 700;
            color: #3a3a3a;
            letter-spacing: -0.5px;
        }
        .logo:hover {
            text-decoration: none;
            color: #2c5f6f;
        }
        .header-center {
            display: flex;
            gap: 15px;
        }
        .date-filter {
            display: flex;
            gap: 15px;
        }
        .filter-link {
            color: #6b6b6b;
            font-size: 15px;
        }
        .filter-link.active {
            color: #2c5f6f;
            font-weight: 700;
        }
        .filter-link:hover {
            color: #2c5f6f;
        }
        .social-icon {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #6b6b6b;
            font-size: 14px;
        }
        .social-icon svg {
            width: 16px;
            height: 16px;
            fill: #6b6b6b;
        }
        .social-icon:hover {
            color: #2c5f6f;
            text-decoration: none;
        }
        .social-icon:hover svg {
            fill: #2c5f6f;
        }
        .content {
            margin: 30px 0;
        }
        .title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 30px;
            color: #3a3a3a;
        }
        .story {
            padding: 25px 0;
            border-bottom: 1px solid #e6e1d6;
            position: relative;
            padding-left: 160px;
            min-height: 100px;
        }
        .story:last-child {
            border-bottom: none;
        }
        .story:hover {
            background-color: #efeae0;
            margin: 0 -15px;
            padding-left: 175px;
            padding-right: 15px;
            border-radius: 4px;
        }
        .story-image {
            position: absolute;
            left: 0;
            top: 25px;
            width: 145px;
            height: 85px;
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #d4cec0;
            background-color: #faf8f3;
        }
        .story:hover .story-image {
            left: 15px;
        }
        .story-image-placeholder {
            position: absolute;
            left: 0;
            top: 25px;
            width: 145px;
            height: 85px;
            border-radius: 4px;
            border: 1px solid #d4cec0;
            background-color: #faf8f3;
            background-image: url('/assets/default-thumbnail.png');
            background-repeat: no-repeat;
            background-position: center;
            background-size: contain;
        }
        .story:hover .story-image-placeholder {
            left: 15px;
        }
        .story-content {
            width: 100%;
        }
        .story-title {
            font-size: 20px;
            line-height: 1.4;
            margin-bottom: 10px;
            font-weight: 700;
            letter-spacing: -0.3px;
        }
        .story-title a {
            color: #2c5f6f;
        }
        .story-title a:hover {
            color: #2c5f6f;
            text-decoration: underline;
        }
        .story-meta {
            font-size: 13px;
            color: #6b6b6b;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 10px;
            align-items: center;
        }
        .story-meta span {
            display: inline-block;
        }
        .source-tag {
            color: #5a5a5a;
            background-color: #e6e1d6;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
        }
        .keyword-tag {
            color: #2c5f6f;
            background-color: #d8e8ed;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 600;
        }
        .story-description {
            font-size: 15px;
            color: #6b6b6b;
            margin-top: 10px;
            line-height: 1.7;
        }
        .empty {
            text-align: center;
            padding: 60px 20px;
            color: #6b6b6b;
        }
        .footer {
            border-top: 2px solid #d4cec0;
            padding: 20px 0;
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            color: #6b6b6b;
        }
        .footer-links {
            display: flex;
            gap: 15px;
        }
        .footer-link {
            color: #6b6b6b;
            font-size: 14px;
        }
        .footer-link:hover {
            color: #2c5f6f;
        }
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin: 35px 0;
            padding: 25px 0;
            border-top: 1px solid #e6e1d6;
        }
        .pagination a {
            color: #2c5f6f;
            padding: 10px 20px;
            border: 1px solid #d4cec0;
            border-radius: 4px;
            font-weight: 600;
        }
        .pagination a:hover {
            background-color: #efeae0;
            text-decoration: none;
            border-color: #2c5f6f;
        }
        .pagination a.disabled {
            color: #6b6b6b;
            pointer-events: none;
            border-color: #e6e1d6;
        }
        .pagination .page-info {
            color: #6b6b6b;
            font-size: 15px;
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="logo">cartero</a>
        <div class="header-center">
            <div class="date-filter">
                <a href="/?date=today" class="filter-link{{if eq .DateRange "today"}} active{{end}}">today</a>
                <a href="/?date=yesterday" class="filter-link{{if eq .DateRange "yesterday"}} active{{end}}">yesterday</a>
            </div>
        </div>
        <a href="https://bsky.app/profile/news.karthihegde.dev" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Follow on Bluesky">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 1024 1024">
                <path d="M351.121 315.106C416.241 363.994 486.281 463.123 512 516.315C537.719 463.123 607.759 363.994 672.879 315.106C719.866 279.83 796 252.536 796 339.388C796 356.734 786.055 485.101 780.222 505.943C759.947 578.396 686.067 596.876 620.347 585.691C735.222 605.242 764.444 670.002 701.333 734.762C581.473 857.754 529.061 703.903 515.631 664.481C513.169 657.254 512.017 653.873 512 656.748C511.983 653.873 510.831 657.254 508.369 664.481C494.939 703.903 442.527 857.754 322.667 734.762C259.556 670.002 288.778 605.242 403.653 585.691C337.933 596.876 264.053 578.396 243.778 505.943C237.945 485.101 228 356.734 228 339.388C228 252.536 304.134 279.83 351.121 315.106Z"></path>
            </svg>
            <span>bluesky</span>
        </a>
    </div>

    <div class="content">
        {{if .DateRange}}
        <div class="title">
            {{if eq .DateRange "yesterday"}}Yesterday's Stories{{else}}Latest Stories{{end}}
        </div>
        {{end}}

        {{if .Entries}}
            {{range .Entries}}
            <div class="story">
                {{if .ImageURL}}
                <img src="{{.ImageURL}}" alt="{{.Title}}" class="story-image" loading="lazy" onerror="this.src='/assets/default-thumbnail.png'">
                {{else}}
                <img src="/assets/default-thumbnail.png" alt="Placeholder" class="story-image-placeholder">
                {{end}}
                <div class="story-content">
                    <div class="story-title">
                        <a href="{{.Link}}" target="_blank" rel="noopener">{{.Title}}</a>
                    </div>
                    <div class="story-meta">
                        <span class="source-tag">{{formatSource .Source}}</span>
                        {{if .MatchedKeywords}}{{range split .MatchedKeywords ","}}<span class="keyword-tag">{{.}}</span>{{end}}{{end}}
                        {{if .Author}}<span>by {{.Author}}</span>{{end}}
                        <span>{{timeAgo .CreatedAt}}</span>
                    </div>
                    {{if .Description}}
                    <div class="story-description">{{.Description}}</div>
                    {{end}}
                </div>
            </div>
            {{end}}

            {{if gt .TotalPages 1}}
            <div class="pagination">
                {{if .HasPrev}}
                <a href="/?date={{.DateRange}}&page={{sub .Page 1}}">← Previous</a>
                {{else}}
                <a class="disabled">← Previous</a>
                {{end}}
                
                <span class="page-info">Page {{.Page}} of {{.TotalPages}} ({{.Total}} stories)</span>
                
                {{if .HasNext}}
                <a href="/?date={{.DateRange}}&page={{add .Page 1}}">Next →</a>
                {{else}}
                <a class="disabled">Next →</a>
                {{end}}
            </div>
            {{end}}
        {{else}}
            <div class="empty">
                <p>No stories yet. Check back soon!</p>
            </div>
        {{end}}
    </div>

    <div class="footer">
        <div class="footer-links">
            <a href="/feed.rss" class="footer-link">rss</a>
            <a href="/feed.atom" class="footer-link">atom</a>
            <a href="/feed.json" class="footer-link">json</a>
        </div>
        <div>last updated: {{.Now.Format "Jan 2, 2006 15:04 MST"}}</div>
    </div>
</body>
</html>
