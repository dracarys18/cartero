<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
    <link rel="canonical" href="{{.Canonical}}">
    <meta name="description" content="{{.Description}}">
    {{if .NoIndex}}<meta name="robots" content="noindex,follow">{{end}}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="cartero">
    <meta property="og:title" content="{{.Title}}">
    <meta property="og:description" content="{{.Description}}">
    <meta property="og:url" content="{{.Canonical}}">
    <meta property="og:image" content="{{.BaseURL}}/assets/favicon.jpg">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{.Title}}">
    <meta name="twitter:description" content="{{.Description}}">
    <meta name="twitter:image" content="{{.BaseURL}}/assets/favicon.jpg">
    <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"WebSite","name":"cartero","url":"{{.BaseURL}}/","potentialAction":{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"{{.BaseURL}}/search?q={search_term_string}"},"query-input":"required name=search_term_string"}}
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXNGBLNTPW"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-XXNGBLNTPW');
    </script>
    <link rel="icon" type="image/jpeg" href="/assets/favicon.jpg">
    <link rel="manifest" href="/assets/manifest.webmanifest">
    <meta name="theme-color" content="#ecebe6" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#171613" media="(prefers-color-scheme: dark)">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --paper:     #ecebe6;
            --ink:       #222221;
            --ink-soft:  #4b4b47;
            --ink-faint: #85847e;
            --rule:      #d8d6ce;
            --field-bg:  #e4e2da;
            --field-bd:  #c7c4ba;
            --accent:    #8f2d1f;
        }
        @media (prefers-color-scheme: dark) {
            :root {
                --paper:     #191817;
                --ink:       #ebe8e0;
                --ink-soft:  #b0aca2;
                --ink-faint: #827e74;
                --rule:      #33302a;
                --field-bg:  #232120;
                --field-bd:  #423e37;
                --accent:    #e0876a;
            }
            .story-thumb img { filter: saturate(.92) brightness(.86); }
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        [hidden] { display: none !important; }
        body {
            background: var(--paper);
            color: var(--ink);
            font-family: "Manrope", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            max-width: 1080px;
            margin: 0 auto;
            padding: 26px 30px 80px;
            -webkit-font-smoothing: antialiased;
        }
        a { text-decoration: none; color: inherit; }

        .topbar {
            display: flex; justify-content: flex-start; align-items: center; gap: 16px;
            padding-bottom: 7px; border-bottom: 1px solid var(--ink);
        }
        .search { display: flex; align-items: stretch; }
        .search input {
            font-family: inherit; font-size: .76rem; color: var(--ink);
            background: transparent; border: 1px solid var(--field-bd); border-right: none;
            padding: 5px 9px; width: 156px; outline: none;
            transition: border-color .15s;
        }
        .search input:focus { border-color: var(--ink-faint); }
        .search button {
            font-family: inherit; font-size: .64rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: .09em; color: var(--ink-soft);
            background: var(--field-bg); border: 1px solid var(--field-bd);
            padding: 5px 13px; cursor: pointer; transition: color .15s;
        }
        .search button:hover { color: var(--accent); }
        .search input:focus + button { border-color: var(--ink-faint); }
        .search input::placeholder { color: var(--ink-faint); }
        .results-head {
            display: flex; justify-content: space-between; align-items: baseline; gap: 12px;
            margin-top: 22px; padding-bottom: 8px; border-bottom: 1px solid var(--rule);
            font-size: .82rem; color: var(--ink-soft);
        }
        .results-head a { color: var(--accent); text-transform: uppercase; letter-spacing: .1em; font-size: .66rem; font-weight: 600; }
        .sections {
            display: flex; gap: 18px;
            text-transform: uppercase; letter-spacing: .13em; font-size: .68rem; font-weight: 600;
        }
        .sections a { color: var(--ink-soft); }
        .sections a:hover { color: var(--accent); }
        .masthead {
            display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px;
            padding: 13px 0 11px; border-bottom: 3px double var(--ink);
        }
        .nameplate {
            justify-self: start;
            font-family: "Manrope", sans-serif; font-weight: 800;
            font-size: 2rem; line-height: 1; letter-spacing: -.03em; color: var(--ink);
        }
        .masthead .dateline { justify-self: center; text-align: center; }
        .masthead .search { justify-self: end; }
        .dateline {
            text-transform: uppercase; letter-spacing: .1em; font-size: .64rem; font-weight: 600;
            color: var(--ink-soft);
        }

        .kicker {
            display: block; text-transform: uppercase; letter-spacing: .12em;
            font-size: .66rem; font-weight: 600; color: var(--accent); margin-bottom: 6px;
        }
        .byline { font-style: normal; color: var(--ink-faint); }
        .title-link:hover { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }

        .stories {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            margin-top: 30px;
            border-top: 1px solid var(--rule);
        }
        .story { padding: 17px 22px 20px; border-bottom: 1px solid var(--rule); border-left: 1px solid var(--rule); }
        .story:nth-child(3n+1) { border-left: none; padding-left: 0; }
        .story:nth-child(3n) { padding-right: 0; }
        .story-thumb { display: block; margin-bottom: 12px; }
        .story-thumb img {
            width: 100%; aspect-ratio: 3 / 2; max-height: 340px; object-fit: cover;
            filter: saturate(.94) contrast(1.02); background: var(--rule);
        }
        .story-title {
            font-family: "Manrope", sans-serif; font-weight: 700;
            font-size: 1.32rem; line-height: 1.15; letter-spacing: -.006em; margin-bottom: 6px;
        }
        .story .byline { font-size: .8rem; margin-bottom: 8px; }
        .share-btn {
            background: none; border: none; cursor: pointer; padding: 0;
            display: inline-flex; align-items: center; gap: 4px; vertical-align: baseline;
            color: var(--ink-faint); font-family: inherit;
            font-size: .68rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em;
        }
        .share-btn:hover { color: var(--accent); }
        .share-btn svg { width: 12px; height: 12px; fill: currentColor; }
        .share-btn.copied { color: var(--accent); }
        .story-excerpt { font-size: .9rem; line-height: 1.52; color: var(--ink-soft); }

        .pagination {
            display: flex; justify-content: center; align-items: center; gap: 24px;
            margin-top: 44px; padding-top: 20px; border-top: 3px double var(--ink);
            text-transform: uppercase; letter-spacing: .1em; font-size: .72rem; font-weight: 600;
        }
        .pagination a { color: var(--ink-soft); }
        .pagination a:hover { color: var(--accent); }
        .pagination .disabled { color: var(--ink-faint); opacity: .5; }
        .page-info { font-style: normal; text-transform: none; letter-spacing: 0; color: var(--ink-faint); font-weight: 400; }

        .empty { padding: 100px 0; text-align: center; font-style: normal; color: var(--ink-soft); }

        .colophon {
            margin-top: 34px; padding-top: 16px; border-top: 1px solid var(--rule);
            display: flex; justify-content: space-between; align-items: center;
            font-size: .74rem; color: var(--ink-faint);
        }
        .colophon a { color: var(--ink-soft); margin-right: 15px; }
        .colophon a:hover { color: var(--accent); }

        @media (max-width: 680px) {
            body { padding: 18px 16px 56px; }
            .topbar { justify-content: center; }
            .sections { flex-wrap: wrap; justify-content: center; gap: 12px 14px; }
            .masthead {
                grid-template-columns: 1fr; justify-items: center; text-align: center; gap: 10px;
            }
            .nameplate { justify-self: center; font-size: 1.9rem; }
            .masthead .search { justify-self: stretch; }
            .search input { flex: 1; width: auto; }
            .stories { grid-template-columns: 1fr; }
            .stories .story { border-left: none; padding-left: 0; padding-right: 0; overflow: hidden; }
            .story-thumb { float: right; width: 104px; margin: 2px 0 6px 14px; }
            .story-thumb img { width: 104px; height: 104px; max-height: none; aspect-ratio: 1; }
            .pagination { flex-wrap: wrap; gap: 12px 18px; }
            .colophon { flex-direction: column; gap: 8px; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="topbar">
        <nav class="sections">
            <a href="/feed.rss">RSS</a>
            <a href="/feed.atom">Atom</a>
            <a href="/feed.json">JSON</a>
            <a href="https://bsky.app/profile/news.karthihegde.dev" target="_blank" rel="noopener">Bluesky</a>
        </nav>
    </div>
    <header class="masthead">
        <a href="/" class="nameplate">cartero</a>
        <span class="dateline">{{.Now.Format "Monday, January 2, 2006"}} · No. {{.Total}}</span>
        <form class="search" method="get" action="/search" role="search">
            <input type="search" name="q" placeholder="Search…" aria-label="Search stories" autocomplete="off">
            <button type="submit">Search</button>
        </form>
    </header>

    <main>
        <div class="results-head" id="results-head" hidden></div>
        <div id="front">
            {{if .Entries}}
            <div class="stories">
                {{range $e := .Entries}}
                <article class="story">
                    {{if $e.ImageURL}}<a class="story-thumb" href="{{$e.Link}}" target="_blank" rel="noopener"><img src="{{$e.ImageURL}}" alt="" loading="lazy" onerror="this.closest('.story-thumb').remove()"></a>{{end}}
                    {{if $e.MatchedKeywords}}<span class="kicker">{{$e.MatchedKeywords}}</span>{{end}}
                    <h3 class="story-title"><a class="title-link" href="{{$e.Link}}" target="_blank" rel="noopener">{{$e.Title}}</a></h3>
                    <div class="byline">{{formatSource $e.Source}} &nbsp;·&nbsp; {{timeAgo $e.CreatedAt}} &nbsp;·&nbsp; <button class="share-btn" data-title="{{$e.Title}}" data-url="{{$e.Link}}" onclick="shareStory(this)" aria-label="Share"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg><span>share</span></button></div>
                    {{if $e.Description}}<p class="story-excerpt">{{$e.Description}}</p>{{end}}
                </article>
                {{end}}
            </div>

            <div class="pagination">
                {{if .HasPrev}}<a href="/?page={{sub .Page 1}}">← Newer</a>{{else}}<span class="disabled">← Newer</span>{{end}}
                <span class="page-info">page {{.Page}} of {{.TotalPages}} · {{.Total}} stories</span>
                {{if .HasNext}}<a href="/?page={{add .Page 1}}">Older →</a>{{else}}<span class="disabled">Older →</span>{{end}}
            </div>
            {{else}}
            <div class="empty">no stories yet</div>
            {{end}}
        </div>
        <div id="results" hidden></div>
    </main>

    <footer class="colophon">
        <div>
            <a href="/feed.rss">RSS</a>
            <a href="/feed.atom">Atom</a>
            <a href="/feed.json">JSON</a>
        </div>
        <div>set by machine · {{.Now.Format "Jan 2, 2006 · 15:04 MST"}}</div>
    </footer>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () { navigator.serviceWorker.register('/sw.js'); });
        }
        function shareStory(btn) {
            const title = btn.dataset.title, url = btn.dataset.url;
            const promo = 'Shared from ' + window.location.origin;
            if (navigator.share) {
                navigator.share({ text: url + '\n\n' + promo }).catch(() => {});
                return;
            }
            const text = title + '\n' + url + '\n\n' + promo;
            navigator.clipboard.writeText(text).then(() => {
                const span = btn.querySelector('span');
                span.textContent = 'copied!';
                btn.classList.add('copied');
                setTimeout(() => { span.textContent = 'share'; btn.classList.remove('copied'); }, 2000);
            });
        }

        (function () {
            const form = document.querySelector('.search');
            const input = form.querySelector('input');
            const front = document.getElementById('front');
            const results = document.getElementById('results');
            const head = document.getElementById('results-head');

            function esc(s) { const d = document.createElement('div'); d.textContent = s == null ? '' : s; return d.innerHTML; }
            function safeURL(u) { try { const p = new URL(u, location.origin); return (p.protocol === 'http:' || p.protocol === 'https:') ? p.href : '#'; } catch (e) { return '#'; } }

            function card(r) {
                const link = safeURL(r.link);
                const thumb = r.image_url ? `<a class="story-thumb" href="${link}" target="_blank" rel="noopener"><img src="${safeURL(r.image_url)}" alt="" loading="lazy" onerror="this.closest('.story-thumb').remove()"></a>` : '';
                const kicker = r.matched_keywords ? `<span class="kicker">${esc(r.matched_keywords)}</span>` : '';
                const excerpt = r.description ? `<p class="story-excerpt">${esc(r.description)}</p>` : '';
                return `<article class="story">${thumb}${kicker}<h3 class="story-title"><a class="title-link" href="${link}" target="_blank" rel="noopener">${esc(r.title)}</a></h3><div class="byline">${esc(r.source)} &nbsp;·&nbsp; ${esc(r.age)}</div>${excerpt}</article>`;
            }

            function showFront() { input.value = ''; results.hidden = true; head.hidden = true; front.hidden = false; }

            async function runSearch(q) {
                front.hidden = true; results.hidden = false; results.innerHTML = '';
                head.hidden = false; head.innerHTML = '<span>searching…</span>';
                let data;
                try {
                    const res = await fetch('/search?q=' + encodeURIComponent(q), { headers: { 'Accept': 'application/json' }, cache: 'no-store' });
                    data = await res.json();
                } catch (e) { head.innerHTML = '<span>search failed</span> <a href="/">← back</a>'; return; }
                head.innerHTML = `<span>results for “${esc(data.query)}”</span> <a href="/" id="back">← back to front page</a>`;
                head.querySelector('#back').addEventListener('click', function (e) { e.preventDefault(); showFront(); });
                results.innerHTML = data.results.length
                    ? '<div class="stories">' + data.results.map(card).join('') + '</div>'
                    : `<div class="empty">No results found for “${esc(data.query)}”.</div>`;
            }

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                const q = input.value.trim();
                if (!q) { showFront(); return; }
                runSearch(q);
            });

            const q0 = new URLSearchParams(location.search).get('q');
            if (q0) { input.value = q0; runSearch(q0); }
        })();
    </script>
</body>
</html>
