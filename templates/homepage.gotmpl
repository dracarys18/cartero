<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cartero</title>
    <link rel="icon" type="image/jpeg" href="/assets/favicon.jpg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background-color: #fafafa;
            color: #1a1a1a;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            line-height: 1.5;
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 20px;
            font-size: 16px;
        }
        a {
            color: #1a1a1a;
            text-decoration: none;
            transition: all 0.2s;
        }
        a:hover {
            color: #000;
        }
        .header {
            border: 3px solid #000;
            padding: 20px 25px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fff;
            box-shadow: 6px 6px 0 #000;
        }
        .logo {
            font-size: 28px;
            font-weight: 900;
            color: #000;
            letter-spacing: -1px;
            text-transform: uppercase;
        }
        .logo:hover {
            color: #000;
        }
        .header-center {
            display: flex;
            gap: 20px;
        }
        .date-filter {
            display: flex;
            gap: 20px;
        }
        .filter-link {
            color: #666;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 6px 12px;
            border: 2px solid transparent;
        }
        .filter-link.active {
            color: #000;
            border: 2px solid #000;
            background: #fff;
        }
        .filter-link:hover {
            color: #000;
            border-color: #000;
        }
        .social-icon {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #666;
            font-size: 13px;
            font-weight: 600;
            padding: 6px 12px;
            border: 2px solid #000;
            background: #fff;
        }
        .social-icon svg {
            width: 16px;
            height: 16px;
            fill: #000;
        }
        .social-icon:hover {
            background: #000;
            color: #fff;
        }
        .social-icon:hover svg {
            fill: #fff;
        }
        .content {
            margin: 40px 0;
        }
        .title {
            font-size: 18px;
            font-weight: 900;
            margin-bottom: 30px;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .story {
            padding: 0;
            margin-bottom: 25px;
            border: 3px solid #000;
            background: #fff;
            display: flex;
            overflow: hidden;
            transition: all 0.2s;
        }
        .story:hover {
            box-shadow: 8px 8px 0 #000;
            transform: translate(-2px, -2px);
        }
        .story-image-container {
            flex-shrink: 0;
            width: 180px;
            height: 180px;
            border-right: 3px solid #000;
            overflow: hidden;
            background: #f0f0f0;
        }
        .story-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .story-content {
            padding: 20px;
            flex: 1;
        }
        .story-title {
            font-size: 18px;
            line-height: 1.3;
            margin-bottom: 12px;
            font-weight: 800;
        }
        .story-title a {
            color: #000;
        }
        .story-title a:hover {
            text-decoration: underline;
            text-decoration-thickness: 3px;
        }
        .story-meta {
            font-size: 12px;
            color: #666;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 12px;
            align-items: center;
        }
        .story-meta span {
            display: inline-block;
        }
        .source-tag {
            color: #000;
            background-color: #fff;
            padding: 4px 10px;
            border: 2px solid #000;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .keyword-tag {
            color: #fff;
            background-color: #000;
            padding: 4px 10px;
            border: 2px solid #000;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .story-description {
            font-size: 14px;
            color: #444;
            line-height: 1.6;
        }
        .empty {
            text-align: center;
            padding: 80px 20px;
            color: #666;
            font-weight: 600;
            border: 3px solid #000;
            background: #fff;
        }
        .footer {
            border: 3px solid #000;
            padding: 20px 25px;
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            background: #fff;
            font-weight: 600;
        }
        .footer-links {
            display: flex;
            gap: 15px;
        }
        .footer-link {
            color: #666;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 8px;
            border: 2px solid transparent;
        }
        .footer-link:hover {
            color: #000;
            border-color: #000;
        }
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin: 40px 0;
        }
        .pagination a {
            color: #000;
            padding: 12px 24px;
            border: 3px solid #000;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 0.5px;
            background: #fff;
            transition: all 0.2s;
        }
        .pagination a:hover {
            background: #000;
            color: #fff;
            box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
        }
        .pagination a.disabled {
            color: #999;
            border-color: #ccc;
            pointer-events: none;
            background: #f5f5f5;
        }
        .pagination .page-info {
            color: #666;
            font-size: 14px;
            font-weight: 600;
        }

        @media (max-width: 768px) {
            body {
                padding: 20px 15px;
            }
            .header {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
                box-shadow: 4px 4px 0 #000;
            }
            .logo {
                font-size: 24px;
            }
            .header-center {
                width: 100%;
                justify-content: center;
            }
            .date-filter {
                gap: 10px;
            }
            .filter-link {
                font-size: 12px;
                padding: 5px 10px;
            }
            .social-icon {
                font-size: 12px;
                padding: 5px 10px;
            }
            .social-icon svg {
                width: 14px;
                height: 14px;
            }
            .story {
                flex-direction: column;
            }
            .story-image-container {
                width: 100%;
                height: 200px;
                border-right: none;
                border-bottom: 3px solid #000;
            }
            .story-content {
                padding: 15px;
            }
            .story-title {
                font-size: 16px;
            }
            .story-description {
                font-size: 13px;
            }
            .story:hover {
                box-shadow: 4px 4px 0 #000;
            }
            .footer {
                flex-direction: column;
                gap: 15px;
                text-align: center;
                padding: 15px;
            }
            .footer-links {
                justify-content: center;
            }
            .pagination {
                flex-wrap: wrap;
                gap: 10px;
            }
            .pagination a {
                padding: 10px 16px;
                font-size: 12px;
            }
            .pagination .page-info {
                width: 100%;
                text-align: center;
                font-size: 13px;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 15px 10px;
            }
            .header {
                padding: 12px;
            }
            .logo {
                font-size: 20px;
            }
            .story-content {
                padding: 12px;
            }
            .story-title {
                font-size: 15px;
            }
            .story-meta {
                font-size: 11px;
                gap: 6px;
            }
            .source-tag,
            .keyword-tag {
                font-size: 10px;
                padding: 3px 8px;
            }
            .story-description {
                font-size: 12px;
            }
            .pagination a {
                padding: 8px 12px;
                font-size: 11px;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="logo">cartero</a>
        <div class="header-center">
            <div class="date-filter">
                <a href="/?date=today" class="filter-link{{if eq .DateRange "today"}} active{{end}}">today</a>
                <a href="/?date=yesterday" class="filter-link{{if eq .DateRange "yesterday"}} active{{end}}">yesterday</a>
            </div>
        </div>
        <a href="https://bsky.app/profile/news.karthihegde.dev" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Follow on Bluesky">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 1024 1024">
                <path d="M351.121 315.106C416.241 363.994 486.281 463.123 512 516.315C537.719 463.123 607.759 363.994 672.879 315.106C719.866 279.83 796 252.536 796 339.388C796 356.734 786.055 485.101 780.222 505.943C759.947 578.396 686.067 596.876 620.347 585.691C735.222 605.242 764.444 670.002 701.333 734.762C581.473 857.754 529.061 703.903 515.631 664.481C513.169 657.254 512.017 653.873 512 656.748C511.983 653.873 510.831 657.254 508.369 664.481C494.939 703.903 442.527 857.754 322.667 734.762C259.556 670.002 288.778 605.242 403.653 585.691C337.933 596.876 264.053 578.396 243.778 505.943C237.945 485.101 228 356.734 228 339.388C228 252.536 304.134 279.83 351.121 315.106Z"></path>
            </svg>
            <span>bluesky</span>
        </a>
    </div>

    <div class="content">
        {{if .DateRange}}
        <div class="title">
            {{if eq .DateRange "yesterday"}}Yesterday's Stories{{else}}Latest Stories{{end}}
        </div>
        {{end}}

        {{if .Entries}}
            {{range .Entries}}
            <div class="story">
                {{if .ImageURL}}
                <div class="story-image-container">
                    <img src="{{.ImageURL}}" alt="{{.Title}}" class="story-image" loading="lazy" onerror="this.classList.add('broken');">
                </div>
                {{end}}
                <div class="story-content">
                    <div class="story-title">
                        <a href="{{.Link}}" target="_blank" rel="noopener">{{.Title}}</a>
                    </div>
                    <div class="story-meta">
                        <span class="source-tag">{{formatSource .Source}}</span>
                        {{if .MatchedKeywords}}{{range split .MatchedKeywords ","}}<span class="keyword-tag">{{.}}</span>{{end}}{{end}}
                        {{if .Author}}<span>by {{.Author}}</span>{{end}}
                        <span>{{timeAgo .CreatedAt}}</span>
                    </div>
                    {{if .Description}}
                    <div class="story-description">{{.Description}}</div>
                    {{end}}
                </div>
            </div>
            {{end}}

            {{if gt .TotalPages 1}}
            <div class="pagination">
                {{if .HasPrev}}
                <a href="/?date={{.DateRange}}&page={{sub .Page 1}}">← Previous</a>
                {{else}}
                <a class="disabled">← Previous</a>
                {{end}}
                
                <span class="page-info">Page {{.Page}} of {{.TotalPages}} ({{.Total}} stories)</span>
                
                {{if .HasNext}}
                <a href="/?date={{.DateRange}}&page={{add .Page 1}}">Next →</a>
                {{else}}
                <a class="disabled">Next →</a>
                {{end}}
            </div>
            {{end}}
        {{else}}
            <div class="empty">
                <p>No stories yet. Check back soon!</p>
            </div>
        {{end}}
    </div>

    <div class="footer">
        <div class="footer-links">
            <a href="/feed.rss" class="footer-link">rss</a>
            <a href="/feed.atom" class="footer-link">atom</a>
            <a href="/feed.json" class="footer-link">json</a>
        </div>
        <div>last updated: {{.Now.Format "Jan 2, 2006 15:04 MST"}}</div>
    </div>
</body>
</html>
